      },
      {
        "id": "dashscope_cn",
        "region": "china",
        "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "probe_model": "qwen-turbo"
      }
    ]
  },
  "grok": {
    "label": "Grok / xAI",
