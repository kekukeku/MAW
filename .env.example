LLM_PROVIDER=litellm
LITELLM_API_BASE=http://localhost:4000
LITELLM_API_KEY=
OPENROUTER_API_KEY=your_key_here
# Direct API keys (when LLM_PROVIDER=direct)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
QWEN_API_KEY=
GROK_API_KEY=
TARGET_PROJECT_PATH=
MAW_MOCK_MODE=0
DEFAULT_COUNCIL_MODELS=openai/gpt-4o,anthropic/claude-3-5-sonnet,google/gemini-3.5-flash,deepseek/deepseek-chat,kimi/moonshot-v1-32k
DEFAULT_CHAIRMAN_MODEL=openai/gpt-4o
ALLOW_AUTO_COMMIT=false
MAX_REVIEW_ITERATIONS=3
EXECUTOR_TIMEOUT_SECONDS=600
REVIEWER_TIMEOUT_SECONDS=300